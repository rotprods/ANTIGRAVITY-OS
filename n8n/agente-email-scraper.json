              "name": "Web",
              "value": "={{$json.Web}}"
            },
            {
              "name": "Correo",
              "value": "={{$json.Correo}}"
            },
            {
              "name": "Correo Icebreaker",
              "value": "={{$json['Correo Icebreaker']}}"
            },
            {
              "name": "Estado",
              "value": "={{$json.Estado}}"
            }
          ]
        },
        "options": {}
      },
