# ============================================
# OCULOPS CHAIN — Environment Variables
# ============================================
# COPY this file to .env and fill in values
# NEVER commit .env to git
# ============================================

# --- Deployer ---
# Private key of the deployer account (with 0x prefix)
# Generate with: node -e "console.log('0x'+require('crypto').randomBytes(32).toString('hex'))"
DEPLOYER_PRIVATE_KEY=0x

# --- XRPL EVM Sidechain ---
# Devnet (for development — free XRP from faucet)
XRPL_EVM_DEVNET_RPC=https://rpc.devnet.xrplevm.org
# Faucet: https://faucet.devnet.xrplevm.org

# Mainnet (DO NOT USE UNTIL READY)
XRPL_EVM_MAINNET_RPC=https://rpc.xrplevm.org

# --- Treasury Config ---
# Addresses for multi-sig treasury (comma-separated)
TREASURY_SIGNERS=0xSIGNER1,0xSIGNER2,0xSIGNER3
TREASURY_THRESHOLD=2

# --- Token Config ---
TOKEN_INITIAL_RECIPIENT=0xTREASURY_ADDRESS

# --- Gas Reporting ---
REPORT_GAS=false

# --- Supabase Integration ---
SUPABASE_URL=https://yxzdafptqtcvpsbqkmkm.supabase.co
SUPABASE_SERVICE_KEY=
